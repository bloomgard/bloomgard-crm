# -------------------------------------------------------------
# Bloomgard erp - Global Environment Configuration
# -------------------------------------------------------------

# Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI API Keys
OPENROUTER_API_KEY=your-openrouter-key
BLAND_API_KEY=your-bland-key

# -------------------------------------------------------------
# Multi-Tenant Email Infrastructure (Postal / OCI)
# -------------------------------------------------------------
# Setting EMAIL_PROVIDER to 'postal' triggers the dedicated Postal OCI node
EMAIL_PROVIDER=postal

# Postal SMTP Host Configuration (Use Grey-Clouded Subdomain or Direct IP)
POSTAL_SMTP_HOST=mail.bloomgard.co

# Postal SMTP Port (Explicitly 2525 or 587 for OCI Ingress Loop)
POSTAL_SMTP_PORT=2525

# SMTP Security (false enables standard STARTTLS upgrade instead of implicit SSL)
POSTAL_SMTP_SECURE=false

# Postal Credentials
POSTAL_SMTP_USER=your-postal-smtp-user
POSTAL_SMTP_PASS=your-postal-smtp-password

# Fallback Resend Configuration (If EMAIL_PROVIDER=resend)
RESEND_API_KEY=your-resend-api-key
